# --------------------------
# AI Providers Configuration
# --------------------------
# You can use OpenAI, Gemini, DeepSeek, or any OpenAI-compatible API.

# 1. OPTION A: Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# 2. OPTION B: OpenAI (ChatGPT)
# OPENAI_API_KEY=your_openai_api_key_here

# 3. OPTION C: DeepSeek / Kimi / OpenAI Compatible APIs
# To use alternative APIs, uncomment the lines below and use your provider's details instead.
# OPENAI_API_KEY=sk_your_alternative_api_key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# Force a specific provider (gemini or openai)
# LLM_PROVIDER=gemini


# --------------------------
# Circle Developer-Controlled Wallets (SCA)
# --------------------------
NEXT_PUBLIC_CLIENT_KEY=your_circle_client_key
NEXT_PUBLIC_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl

CIRCLE_API_KEY=your_circle_developer_api_key
CIRCLE_ENTITY_SECRET=your_32_byte_hex_entity_secret


# --------------------------
# Telegram Bot Integration
# --------------------------
# Required to handle wallet creation and mini app linking locally/Vercel
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --------------------------
# General Configurations
# --------------------------
NEXT_PUBLIC_URL=http://localhost:3000

